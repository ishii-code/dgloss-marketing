# dgloss-marketing 問い合わせ流入分析ツール（.env にコピーして使う）

# --- データベース（Supabase / Postgres）---
# Supabase の接続文字列を優先。無ければ DATABASE_URL。
SUPABASE_DATABASE_URL=
DATABASE_URL=postgres://user:pass@host:5432/dgloss_marketing
DATABASE_SSL=false

# --- ダッシュボードのログイン（共通パスワード）---
# ダッシュボード閲覧に必要なパスワード。未設定だと閲覧がロックされる（設定必須）。
DASHBOARD_PASSWORD=change-me-please
# セッション Cookie の署名鍵（32文字以上推奨）。
AUTH_SECRET=change-me-please-32-chars-or-more

# --- 問い合わせ受信（自社サイトのフォーム計測）---
# 計測タグ/フォームからの受信を有効にするトークン（任意の長い文字列）。未設定だと受信は無効。
# ここに入れた値と同じものを、サイトに貼る計測タグの data-token に設定する。
INQUIRY_INGEST_TOKEN=
# 自社ドメイン（このドメインからのリファラは「直接（サイト内遷移）」として扱う）。
INQUIRY_OWN_DOMAIN=dgloss.co.jp
# 受信を許可するオリジン（カンマ区切り・任意）。未設定なら全許可（トークンで保護）。
# 例: INQUIRY_ALLOWED_ORIGINS=https://dgloss.co.jp,https://www.dgloss.co.jp
INQUIRY_ALLOWED_ORIGINS=

# ローカル実行時のポート。
PORT=3000
